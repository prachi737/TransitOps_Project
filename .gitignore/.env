# Copy this file to .env and fill in your MySQL credentials.
# .env should NOT be committed to git.

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=devpassword
DB_NAME=transitops

# Max simultaneous connections the app pool will open to MySQL.
# Tune this to your MySQL server's max_connections and how many
# app instances you're running behind it.
DB_POOL_SIZE=10

SESSION_SECRET=change-this-secret-key
PORT=3000
