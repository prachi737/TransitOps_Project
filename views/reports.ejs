<%- include('partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h3>Reports & Analytics</h3>
  <a href="/reports/export.csv" class="btn btn-outline-primary">Export CSV</a>
</div>

<div class="card mb-3 shadow-sm">
  <div class="card-body">
    <strong>Fleet Utilization:</strong> <%= fleetUtilization %>%
  </div>
</div>

<div class="table-responsive">
<table class="table table-striped bg-white shadow-sm">
  <thead>
    <tr>
      <th>Vehicle</th><th>Name</th><th>Fuel Efficiency (dist/liter)</th>
      <th>Operational Cost</th><th>Revenue</th><th>ROI</th>
    </tr>
  </thead>
  <tbody>
    <% rows.forEach(r => { %>
    <tr>
      <td><%= r.regNumber %></td>
      <td><%= r.name %></td>
      <td><%= r.fuelEfficiency %></td>
      <td><%= r.operationalCost %></td>
      <td><%= r.revenue %></td>
      <td><%= r.roi %></td>
    </tr>
    <% }); %>
  </tbody>
</table>
</div>
<p class="text-muted">
  ROI = (Revenue − (Maintenance + Fuel + Other Expenses)) / Acquisition Cost.
  Enter a "Revenue" value when completing a trip so ROI can be calculated.
  Charts (bonus feature) can be added here later with Chart.js.
</p>
<%- include('partials/footer') %>
