<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TransitOps — Smart Transport Operations Platform</title>
  <script>
    document.documentElement.dataset.theme = localStorage.getItem('transitops-theme') || 'dark';
  </script>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
<% if (typeof currentUser !== "undefined" && currentUser) { %>
<nav class="navbar navbar-expand-lg navbar-custom mb-4">
  <div class="container-fluid">
    <a class="navbar-brand" href="/dashboard">
      <i class="bi bi-truck"></i> TransitOps
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav" aria-controls="nav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="nav">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link" href="/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
        
        <% if (currentUser.role === 'fleet_manager' || currentUser.role === 'driver' || currentUser.role === 'safety_officer' || currentUser.role === 'financial_analyst') { %>
          <li class="nav-item"><a class="nav-link" href="/vehicles"><i class="bi bi-car-front"></i> Vehicles</a></li>
        <% } %>

        <% if (currentUser.role === 'fleet_manager' || currentUser.role === 'driver' || currentUser.role === 'safety_officer') { %>
          <li class="nav-item"><a class="nav-link" href="/drivers"><i class="bi bi-people"></i> Drivers</a></li>
        <% } %>

        <% if (currentUser.role === 'fleet_manager' || currentUser.role === 'driver' || currentUser.role === 'safety_officer') { %>
          <li class="nav-item"><a class="nav-link" href="/trips"><i class="bi bi-map"></i> Trips</a></li>
        <% } %>

        <% if (currentUser.role === 'fleet_manager' || currentUser.role === 'safety_officer') { %>
          <li class="nav-item"><a class="nav-link" href="/maintenance"><i class="bi bi-tools"></i> Maintenance</a></li>
        <% } %>

        <% if (currentUser.role === 'fleet_manager' || currentUser.role === 'driver' || currentUser.role === 'financial_analyst') { %>
          <li class="nav-item"><a class="nav-link" href="/fuel-expenses"><i class="bi bi-fuel-pump"></i> Fuel & Expenses</a></li>
        <% } %>

        <% if (currentUser.role === 'fleet_manager' || currentUser.role === 'financial_analyst') { %>
          <li class="nav-item"><a class="nav-link" href="/reports"><i class="bi bi-bar-chart-line"></i> Reports</a></li>
        <% } %>
      </ul>
      <div class="d-flex align-items-center gap-3">
        <span class="navbar-text">
          <i class="bi bi-person-circle"></i> <%= currentUser.name %> 
          <span class="badge bg-secondary-custom ms-1">
            <%= currentUser.role.replace('_', ' ').toUpperCase() %>
          </span>
        </span>
        <button type="button" class="btn btn-theme-toggle btn-sm" id="themeToggle" aria-label="Switch to light mode" title="Switch theme">
          <i class="bi bi-sun-fill"></i>
          <span class="theme-toggle-label">Light mode</span>
        </button>
        <a class="btn btn-outline-custom btn-sm" href="/logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
      </div>
    </div>
  </div>
</nav>
<% } %>
<div class="container pb-5">
  <% if (typeof flash !== "undefined" && flash) { %>
    <div class="alert alert-custom alert-custom-<%= flash.type %> alert-dismissible fade show" role="alert">
      <% if (flash.type === 'success') { %>
        <i class="bi bi-check-circle-fill text-success me-2"></i>
      <% } else if (flash.type === 'danger') { %>
        <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>
      <% } else { %>
        <i class="bi bi-info-circle-fill text-warning me-2"></i>
      <% } %>
      <%= flash.msg %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
