<%- include('partials/header') %>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
  <div>
    <h1 class="page-title mb-1">Trip Management</h1>
    <p class="text-muted mb-0">Dispatch vehicles, assign drivers, and monitor dispatch lifecycle</p>
  </div>
  
  <button class="btn btn-primary-custom" data-bs-toggle="modal" data-bs-target="#createTripModal">
    <i class="bi bi-plus-circle me-1"></i> Create Dispatch Trip
  </button>
</div>

<!-- Search & Filtering Section -->
<div class="filter-panel mb-4">
  <div class="row g-3">
    <div class="col-md-8">
      <label class="form-label text-muted small fw-semibold">Search Route</label>
      <div class="input-group">
        <span class="input-group-text bg-transparent border-secondary border-opacity-25 text-muted"><i class="bi bi-search"></i></span>
        <input type="text" id="tripSearch" class="form-control form-control-custom" placeholder="Search by source or destination..." onkeyup="filterTripsTable()">
      </div>
    </div>
    
    <div class="col-md-4">
      <label class="form-label text-muted small fw-semibold">Filter by Status</label>
      <select id="tripStatusFilter" class="form-select form-select-custom" onchange="filterTripsTable()">
        <option value="">All Statuses</option>
        <option value="Draft">Draft</option>
        <option value="Dispatched">Dispatched</option>
        <option value="Completed">Completed</option>
        <option value="Cancelled">Cancelled</option>
      </select>
    </div>
  </div>
</div>

<!-- Table -->
<div class="table-custom-container">
  <table class="table table-custom" id="tripsTable">
    <thead>
      <tr>
        <th>Trip ID</th>
        <th>Route Details</th>
        <th>Vehicle Asset</th>
        <th>Assigned Driver</th>
        <th class="text-end">Cargo Load</th>
        <th class="text-end">Planned Dist.</th>
        <th>Status</th>
        <th class="text-center">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (trips.length === 0) { %>
        <tr>
          <td colspan="8" class="text-center py-4 text-muted">
            <i class="bi bi-map-fill fs-2 d-block mb-2"></i> No trips dispatched yet.
          </td>
        </tr>
      <% } %>
      <% trips.forEach(t => { %>
        <tr data-status="<%= t.status %>">
          <td class="fw-bold text-white">#<%= t.id %></td>
          <td>
            <div class="fw-semibold text-white">
              <%= t.source %> <i class="bi bi-arrow-right text-indigo px-1"></i> <%= t.destination %>
            </div>
          </td>
          <td>
            <% if (t.vehicle) { %>
              <div class="text-white"><%= t.vehicle.name %></div>
              <span class="small text-muted"><%= t.vehicle.regNumber %></span>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
          <td>
            <% if (t.driver) { %>
              <div class="text-white"><%= t.driver.name %></div>
              <span class="small text-muted">Lic: <%= t.driver.licenseNumber %></span>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
          <td class="text-end text-white"><%= t.cargoWeight.toLocaleString() %> kg</td>
          <td class="text-end text-white"><%= t.plannedDistance.toLocaleString() %> km</td>
          <td>
            <% 
              let badgeClass = 'badge-draft';
              if (t.status === 'Dispatched') badgeClass = 'badge-ontrip';
              else if (t.status === 'Completed') badgeClass = 'badge-available';
              else if (t.status === 'Cancelled') badgeClass = 'badge-retired';
            %>
            <span class="badge-custom <%= badgeClass %>"><%= t.status %></span>
          </td>
          <td class="text-center">
            <% if (t.status === "Draft") { %>
              <div class="d-inline-flex gap-2">
                <form method="POST" action="/trips/<%= t.id %>/dispatch" style="display:inline">
                  <button type="submit" class="btn btn-sm btn-primary-custom py-1 px-3">
                    <i class="bi bi-telegram"></i> Dispatch
                  </button>
                </form>
                <form method="POST" action="/trips/<%= t.id %>/cancel" style="display:inline">
                  <button type="submit" class="btn btn-sm btn-outline-danger py-1 px-3">
                    <i class="bi bi-x-circle"></i> Cancel
                  </button>
                </form>
              </div>
            <% } else if (t.status === "Dispatched") { %>
              <div class="d-inline-flex gap-2">
                <button class="btn btn-sm btn-success py-1 px-3" style="border-radius: var(--radius-md);" data-bs-toggle="modal" data-bs-target="#completeModal<%= t.id %>">
                  <i class="bi bi-check-circle"></i> Complete
                </button>
                <form method="POST" action="/trips/<%= t.id %>/cancel" style="display:inline">
                  <button type="submit" class="btn btn-sm btn-outline-danger py-1 px-3">
                    <i class="bi bi-x-circle"></i> Cancel
                  </button>
                </form>
              </div>

              <!-- Complete Trip Modal -->
              <div class="modal fade modal-custom" id="completeModal<%= t.id %>" tabindex="-1">
                <div class="modal-dialog">
                  <form method="POST" action="/trips/<%= t.id %>/complete">
                    <div class="modal-content text-start">
                      <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-check-circle me-2"></i>Complete Trip #<%= t.id %></h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                      </div>
                      <div class="modal-body">
                        <p class="text-muted small">Enter the final odometer and fuel metrics to calculate reports and ROI.</p>
                        
                        <div class="mb-3">
                          <label class="form-label text-muted small">Final Odometer Reading (km)</label>
                          <input name="finalOdometer" type="number" step="0.01" class="form-control form-control-custom" placeholder="e.g. <%= t.vehicle ? t.vehicle.odometer + t.plannedDistance : '' %>" required>
                          <span class="small text-muted">Current vehicle odometer is: <%= t.vehicle ? t.vehicle.odometer : 0 %> km</span>
                        </div>
                        
                        <div class="mb-3">
                          <label class="form-label text-muted small">Fuel Consumed (Liters)</label>
                          <input name="fuelConsumed" type="number" step="0.01" class="form-control form-control-custom" placeholder="e.g. 50" required>
                        </div>
                        
                        <div class="mb-3">
                          <label class="form-label text-muted small">Revenue Earned ($)</label>
                          <input name="revenue" type="number" step="0.01" class="form-control form-control-custom" placeholder="e.g. 1500">
                        </div>
                      </div>
                      <div class="modal-footer">
                        <button type="button" class="btn btn-secondary-custom" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success" style="border-radius: var(--radius-md); padding: 0.75rem 1.5rem; font-weight:600;">Complete Trip</button>
                      </div>
                    </div>
                  </form>
                </div>
              </div>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<!-- Create Trip Modal -->
<div class="modal fade modal-custom" id="createTripModal" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="/trips/create">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-map me-2"></i>Create New Dispatch</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body text-start">
          <div class="mb-3">
            <label class="form-label text-muted small">Source Location</label>
            <input name="source" class="form-control form-control-custom" placeholder="e.g. WareHouse A, Seattle" required>
          </div>
          
          <div class="mb-3">
            <label class="form-label text-muted small">Destination Location</label>
            <input name="destination" class="form-control form-control-custom" placeholder="e.g. WareHouse B, San Francisco" required>
          </div>
          
          <div class="mb-3">
            <label class="form-label text-muted small">Select Vehicle</label>
            <select name="vehicleId" class="form-select form-select-custom" required>
              <% if (vehicles.length === 0) { %>
                <option value="">No available vehicles</option>
              <% } %>
              <% vehicles.forEach(v => { %>
                <option value="<%= v.id %>"><%= v.regNumber %> — <%= v.name %> (Max Capacity: <%= v.maxLoad %> kg)</option>
              <% }); %>
            </select>
          </div>
          
          <div class="mb-3">
            <label class="form-label text-muted small">Select Driver</label>
            <select name="driverId" class="form-select form-select-custom" required>
              <% if (drivers.length === 0) { %>
                <option value="">No available drivers with valid licenses</option>
              <% } %>
              <% drivers.forEach(d => { %>
                <option value="<%= d.id %>"><%= d.name %> (Lic: <%= d.licenseNumber %>)</option>
              <% }); %>
            </select>
          </div>
          
          <div class="mb-3">
            <label class="form-label text-muted small">Cargo Weight (kg)</label>
            <input name="cargoWeight" type="number" step="0.01" class="form-control form-control-custom" placeholder="e.g. 450" required>
          </div>
          
          <div class="mb-3">
            <label class="form-label text-muted small">Planned Distance (km)</label>
            <input name="plannedDistance" type="number" step="0.01" class="form-control form-control-custom" placeholder="e.g. 350" required>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary-custom" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary-custom">Create Draft</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
  function filterTripsTable() {
    const searchVal = document.getElementById('tripSearch').value.toLowerCase();
    const statusVal = document.getElementById('tripStatusFilter').value;
    
    const rows = document.querySelectorAll('#tripsTable tbody tr');
    
    rows.forEach(row => {
      if (row.cells.length === 1 && row.cells[0].colSpan > 1) return;
      
      const routeText = row.cells[1].textContent.toLowerCase();
      const status = row.getAttribute('data-status');
      
      const matchesSearch = routeText.includes(searchVal);
      const matchesStatus = !statusVal || status === statusVal;
      
      if (matchesSearch && matchesStatus) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });
  }
</script>

<%- include('partials/footer') %>

