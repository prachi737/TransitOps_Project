<%- include('partials/header') %>

<% const dashboardFilters = typeof filters === "undefined" ? {
  types: [],
  regions: [],
  statuses: [],
  selectedType: "",
  selectedStatus: "",
  selectedRegion: ""
} : filters; %>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
  <div>
    <h1 class="page-title mb-1">Fleet Operations Dashboard</h1>
    <p class="text-muted mb-0">Real-time tracking, metrics, and fleet utilization</p>
  </div>
  
  <div class="d-flex align-items-center gap-2">
    <a href="/dashboard" class="btn btn-secondary-custom btn-sm"><i class="bi bi-arrow-clockwise"></i> Reset Filters</a>
  </div>
</div>

<!-- Quick Actions -->
<div class="quick-actions mb-4">
  <span class="quick-actions-label"><i class="bi bi-lightning-charge-fill"></i> Quick actions</span>
  <div class="d-flex flex-wrap gap-2">
    <% if (currentUser.role === 'fleet_manager' || currentUser.role === 'driver' || currentUser.role === 'safety_officer') { %>
      <a href="/trips" class="btn btn-primary-custom btn-sm"><i class="bi bi-send-plus me-1"></i> Manage Trips</a>
    <% } %>
    <% if (currentUser.role === 'fleet_manager') { %>
      <a href="/vehicles" class="btn btn-secondary-custom btn-sm"><i class="bi bi-car-front-fill me-1"></i> Register Vehicle</a>
    <% } %>
    <% if (currentUser.role === 'fleet_manager' || currentUser.role === 'safety_officer') { %>
      <a href="/maintenance" class="btn btn-secondary-custom btn-sm"><i class="bi bi-tools me-1"></i> Maintenance</a>
    <% } %>
    <% if (currentUser.role === 'fleet_manager' || currentUser.role === 'financial_analyst') { %>
      <a href="/reports" class="btn btn-secondary-custom btn-sm"><i class="bi bi-bar-chart-line me-1"></i> View Reports</a>
    <% } %>
  </div>
</div>

<!-- Filters Panel -->
<div class="filter-panel mb-4">
  <form method="GET" action="/dashboard" class="row g-3">
    <div class="col-md-3 col-sm-6">
      <label class="form-label text-muted small fw-semibold">Vehicle Type</label>
      <select name="type" class="form-select form-select-custom" onchange="this.form.submit()">
        <option value="">All Types</option>
        <% dashboardFilters.types.forEach(t => { %>
          <option value="<%= t %>" <%= dashboardFilters.selectedType === t ? 'selected' : '' %>><%= t.charAt(0).toUpperCase() + t.slice(1) %></option>
        <% }); %>
      </select>
    </div>
    
    <div class="col-md-3 col-sm-6">
      <label class="form-label text-muted small fw-semibold">Status</label>
      <select name="status" class="form-select form-select-custom" onchange="this.form.submit()">
        <option value="">All Statuses</option>
        <% dashboardFilters.statuses.forEach(s => { %>
          <option value="<%= s %>" <%= dashboardFilters.selectedStatus === s ? 'selected' : '' %>><%= s %></option>
        <% }); %>
      </select>
    </div>
    
    <div class="col-md-3 col-sm-6">
      <label class="form-label text-muted small fw-semibold">Region</label>
      <select name="region" class="form-select form-select-custom" onchange="this.form.submit()">
        <option value="">All Regions</option>
        <% dashboardFilters.regions.forEach(r => { %>
          <option value="<%= r %>" <%= dashboardFilters.selectedRegion === r ? 'selected' : '' %>><%= r %></option>
        <% }); %>
      </select>
    </div>
    
    <div class="col-md-3 col-sm-6 d-flex align-items-end">
      <button type="submit" class="btn btn-primary-custom w-100"><i class="bi bi-funnel-fill me-1"></i> Apply Filters</button>
    </div>
  </form>
</div>

<!-- KPI Grid -->
<div class="row g-3 mb-4">
  <% 
    const kpiList = [
      { label: "Active Vehicles", value: kpis.activeVehicles, color: "rgba(99, 102, 241, 0.1)", border: "#6366f1", icon: "bi-car-front", text: "#a5b4fc" },
      { label: "Available Vehicles", value: kpis.availableVehicles, color: "rgba(16, 185, 129, 0.1)", border: "#10b981", icon: "bi-check-circle", text: "#6ee7b7" },
      { label: "In Maintenance", value: kpis.inMaintenance, color: "rgba(245, 158, 11, 0.1)", border: "#f59e0b", icon: "bi-tools", text: "#fde047" },
      { label: "Active Trips", value: kpis.activeTrips, color: "rgba(6, 182, 212, 0.1)", border: "#06b6d4", icon: "bi-map", text: "#67e8f9" },
      { label: "Pending Trips", value: kpis.pendingTrips, color: "rgba(100, 116, 139, 0.1)", border: "#64748b", icon: "bi-hourglass-split", text: "#cbd5e1" },
      { label: "Drivers On Duty", value: kpis.driversOnDuty, color: "rgba(168, 85, 247, 0.1)", border: "#a855f7", icon: "bi-person-badge", text: "#d8b4fe" },
    ]; 
  %>

  <% kpiList.forEach(kpi => { %>
    <div class="col-md-4 col-sm-6">
      <div class="card kpi-card-custom h-100" style="background: <%= kpi.color %>; border: 1px solid <%= kpi.border %>33;">
        <div class="card-body d-flex align-items-center justify-content-between p-4">
          <div>
            <div class="fs-4 text-muted mb-1 small fw-semibold"><%= kpi.label %></div>
            <div class="fs-1 fw-bold" style="color: <%= kpi.text %>"><%= kpi.value %></div>
          </div>
          <div class="fs-1 opacity-75" style="color: <%= kpi.text %>">
            <i class="bi <%= kpi.icon %>"></i>
          </div>
        </div>
      </div>
    </div>
  <% }); %>

  <!-- Fleet Utilization Large Card -->
  <div class="col-12 mt-4">
    <div class="card card-custom">
      <div class="card-body p-4 d-flex flex-column flex-md-row align-items-center justify-content-between gap-4">
        <div>
          <h4 class="mb-1"><i class="bi bi-activity text-danger me-2"></i>Fleet Utilization Rate</h4>
          <p class="text-muted mb-0">Percentage of active, non-retired vehicles currently dispatched on trips</p>
        </div>
        <div class="d-flex align-items-center gap-4">
          <div class="progress" style="width: 200px; height: 12px; background-color: rgba(255,255,255,0.05); border-radius: 999px;">
            <div class="progress-bar bg-danger" role="progressbar" style="width: <%= kpis.fleetUtilization %>%" aria-valuenow="<%= kpis.fleetUtilization %>" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
          <span class="fs-2 fw-bold text-danger"><%= kpis.fleetUtilization %>%</span>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-lg-7">
    <div class="card card-custom h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-pie-chart-fill text-info me-2"></i>Fleet status overview</span>
        <span class="small text-muted">Current filtered fleet</span>
      </div>
      <div class="card-body chart-wrapper">
        <canvas id="fleetStatusChart" aria-label="Fleet status overview chart"></canvas>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card card-custom h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-bell-fill text-warning me-2"></i>Attention required</span>
        <% if (attentionItems.length) { %><span class="badge bg-danger rounded-pill"><%= attentionItems.length %></span><% } %>
      </div>
      <div class="card-body py-2">
        <% if (attentionItems.length === 0) { %>
          <div class="dashboard-empty-state">
            <i class="bi bi-check2-circle"></i>
            <p class="mb-0">Everything is running smoothly.</p>
          </div>
        <% } else { %>
          <% attentionItems.slice(0, 4).forEach(item => { %>
            <a href="<%= item.href %>" class="attention-item attention-<%= item.level %>">
              <i class="bi <%= item.icon %>"></i>
              <span><strong><%= item.title %></strong><small><%= item.detail %></small></span>
              <i class="bi bi-chevron-right attention-chevron"></i>
            </a>
          <% }); %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
  const fleetChart = document.getElementById('fleetStatusChart');
  let fleetStatusChart;
  function renderFleetChart() {
    if (fleetStatusChart) fleetStatusChart.destroy();
    const isLightTheme = document.documentElement.dataset.theme === 'light';
    fleetStatusChart = new Chart(fleetChart, {
      type: 'doughnut',
      data: {
        labels: <%- JSON.stringify(chartData.labels) %>,
        datasets: [{
          data: <%- JSON.stringify(chartData.values) %>,
          backgroundColor: ['#10b981', '#06b6d4', '#f59e0b', '#f43f5e'],
          borderColor: isLightTheme ? '#ffffff' : '#131b2e',
          borderWidth: 5,
          hoverOffset: 8
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '68%',
        plugins: {
          legend: { position: 'bottom', labels: { color: isLightTheme ? '#334155' : '#cbd5e1', padding: 18, usePointStyle: true } },
          tooltip: { displayColors: false }
        }
      }
    });
  }
  renderFleetChart();
  window.addEventListener('transitops-theme-change', renderFleetChart);
</script>

<%- include('partials/footer') %>
