<%- include('partials/header') %>
<h3 class="mb-3">Fuel & Expense Management</h3>

<div class="row">
  <div class="col-md-6">
    <div class="d-flex justify-content-between align-items-center">
      <h5>Fuel Logs</h5>
      <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addFuelModal">+ Add Fuel Log</button>
    </div>
    <table class="table table-striped bg-white shadow-sm">
      <thead><tr><th>Vehicle</th><th>Liters</th><th>Cost</th><th>Date</th></tr></thead>
      <tbody>
        <% fuelLogs.forEach(f => { %>
        <tr><td><%= f.vehicle ? f.vehicle.regNumber : '—' %></td><td><%= f.liters %></td><td><%= f.cost %></td><td><%= f.date %></td></tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <div class="col-md-6">
    <div class="d-flex justify-content-between align-items-center">
      <h5>Other Expenses</h5>
      <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addExpenseModal">+ Add Expense</button>
    </div>
    <table class="table table-striped bg-white shadow-sm">
      <thead><tr><th>Vehicle</th><th>Category</th><th>Amount</th><th>Date</th></tr></thead>
      <tbody>
        <% expenses.forEach(e => { %>
        <tr><td><%= e.vehicle ? e.vehicle.regNumber : '—' %></td><td><%= e.category %></td><td><%= e.amount %></td><td><%= e.date %></td></tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<!-- Add Fuel Modal -->
<div class="modal fade" id="addFuelModal" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="/fuel-expenses/add-fuel">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Add Fuel Log</h5></div>
        <div class="modal-body">
          <div class="mb-2"><label class="form-label">Vehicle</label>
            <select name="vehicleId" class="form-select" required>
              <% vehicles.forEach(v => { %><option value="<%= v.id %>"><%= v.regNumber %></option><% }); %>
            </select>
          </div>
          <div class="mb-2"><label class="form-label">Liters</label>
            <input name="liters" type="number" step="0.01" class="form-control" required></div>
          <div class="mb-2"><label class="form-label">Cost</label>
            <input name="cost" type="number" step="0.01" class="form-control" required></div>
          <div class="mb-2"><label class="form-label">Date</label>
            <input name="date" type="date" class="form-control" required></div>
        </div>
        <div class="modal-footer"><button type="submit" class="btn btn-primary">Save</button></div>
      </div>
    </form>
  </div>
</div>

<!-- Add Expense Modal -->
<div class="modal fade" id="addExpenseModal" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="/fuel-expenses/add-expense">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Add Expense</h5></div>
        <div class="modal-body">
          <div class="mb-2"><label class="form-label">Vehicle</label>
            <select name="vehicleId" class="form-select" required>
              <% vehicles.forEach(v => { %><option value="<%= v.id %>"><%= v.regNumber %></option><% }); %>
            </select>
          </div>
          <div class="mb-2"><label class="form-label">Category</label>
            <input name="category" class="form-control" placeholder="Toll, Fine, Other" required></div>
          <div class="mb-2"><label class="form-label">Amount</label>
            <input name="amount" type="number" step="0.01" class="form-control" required></div>
          <div class="mb-2"><label class="form-label">Date</label>
            <input name="date" type="date" class="form-control" required></div>
        </div>
        <div class="modal-footer"><button type="submit" class="btn btn-primary">Save</button></div>
      </div>
    </form>
  </div>
</div>
<%- include('partials/footer') %>
